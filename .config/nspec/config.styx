// Porting spec config. The upstream C++ sources live in
// pytorch/executorch (the porting reference, pinned in plan/main.styx);
// this repo carries only the Rust target-impl.
specs ({
    name et,
    include (docs/spec/**/*.md),
    impls (
        {name target-impl, languages (@rust), include (crates/**/*.rs), exclude (target/**), mode @both}
    )
})
